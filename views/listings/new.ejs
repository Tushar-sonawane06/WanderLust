<% layout("/layouts/boilerplate.ejs") %>
<style>
    .add-listing-page{
        background-image:url("/images/newAir.jpg");
    }
</style>
<div class="add-listing-page">

    <div class="form-container">

        <h2 class="form-title">List Your Property</h2>
        <p class="form-subtitle">Share your space with travelers around the world.</p>

        <form method="POST" action="/listings" class="needs-validation" novalidate enctype="multipart/form-data">

            <div class="mb-3">
                <label class="form-label">Title</label>
                <input name="listing[title]" placeholder="Add a Catchy Title" type="text" class="form-control" required>
                <div class="valid-feedback">Title Looks Great!</div>
            </div>

            <div class="mb-3">
                <label class="form-label">Description</label>
                <textarea name="listing[description]" placeholder="Enter the Description" class="form-control" required></textarea>
                <div class="invalid-feedback">Please Enter Description!</div>
            </div>

            <div class="mb-3">
                <label class="form-label">Upload Listing Image</label>
                <input name="listing[image]" type="file" class="form-control">
            </div>

            <div class="row">
                <div class="mb-3 col-md-6">
                    <label class="form-label">Location</label>
                    <input name="listing[location]" placeholder="Jaipur, Rajasthan" type="text" class="form-control" required>
                    <div class="invalid-feedback">Please Enter Location!</div>
                </div>

                <div class="mb-3 col-md-6">
                    <label class="form-label">Country</label>
                    <input name="listing[country]" placeholder="India" type="text" class="form-control" required>
                    <div class="invalid-feedback">Please Enter Country Name!</div>
                </div>
            </div>

            <div class="row">
                <div class="mb-3 col-md-6">
                    <label class="form-label">Price</label>
                    <input name="listing[price]" placeholder="1700" type="number" class="form-control" required>
                    <div class="invalid-feedback">Please Enter Valid Price!</div>
                </div>

                <div class="mb-3 col-md-6">
                    <label class="form-label">Hotel Type</label>
                    <select name="listing[hotelType]" class="form-control" required>
                        <option value="">Select Hotel Type</option>
                        <option value="Rooms">Rooms</option>
                        <option value="Iconic Cities">Iconic Cities</option>
                        <option value="Mountains">Mountains</option>
                        <option value="Castles">Castles</option>
                        <option value="Pools">Pools</option>
                        <option value="Camping">Camping</option>
                        <option value="Farms">Farms</option>
                        <option value="Artic">Artic</option>
                        <option value="Domes">Domes</option>
                        <option value="Boats">Boats</option>
                    </select>
                    <div class="invalid-feedback">Please select the Type</div>
                </div>
            </div>
            <div class="d-flex justify-content-center">
                <button class="btn add-btn mt-3">Add Listing</button>
            </div>

        </form>

    </div>

</div>
    