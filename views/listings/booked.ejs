<% layout("/layouts/boilerplate.ejs") %>
<div class="booked-page">
<h2 class="text-center booking-heading">My Bookings</h2>

<% if (!bookings || bookings.length === 0) { %>
  <p class="text-center booking-heading">No bookings yet.</p>
<% } %>

<div class="cards-container">

    <% if (bookings) { %>
      <% for(let booking of bookings){ %>
  
        <div class="hotel-card">
  
          <!-- Clickable area -->
          <a href="/listings/<%= booking.listing._id %>" class="card-link">
  
            <img 
              src="<%= booking.listing.images && booking.listing.images.length ? booking.listing.images[0].url : '' %>" 
              alt="hotel image"
              class="hotel-img"
            >
  
            <div class="card-content">
              <h3><%= booking.listing.title %></h3>
              <p class="location"><%= booking.listing.location %></p>
              <p class="price">₹ <%= booking.totalPrice.toLocaleString("en-IN") %> total</p>
  
              <p class="dates">
                Check-in: <%= booking.checkIn.toDateString() %><br>
                Check-out: <%= booking.checkOut.toDateString() %>
              </p>
            </div>
  
          </a>
  
          <!-- Action section -->
          <div class="card-actions">
  
            <p class="status">
              <% if (booking.status === "cancelled") { %>
                ❌ Cancelled
              <% } else { %>
                ✅ Confirmed
              <% } %>
            </p>
  
            <% if (booking.status === "confirmed") { %>
              <form action="/bookings/<%= booking._id %>?_method=DELETE" method="POST">
                <button class="cancel-btn">Cancel Booking</button>
              </form>
            <% } else { %>
              <button class="cancel-btn disabled">Booking Cancelled</button>
            <% } %>
  
          </div>
  
        </div>
  
      <% } %>
    <% } %>
  
  </div>
</div>