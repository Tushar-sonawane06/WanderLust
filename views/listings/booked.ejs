<% layout("/layouts/boilerplate.ejs") %>
<div class="booked-page">
<h2 class="text-center booking-heading">My Bookings</h2>

<% if (!bookings || bookings.length === 0) { %>
  <p class="text-center booking-heading">No bookings yet.</p>
<% } %>

<div class="card-wrapper">
<div class="row mt-3 row-cols-1 row-cols-md-2 row-cols-lg-3 g-4 card-wrapper">
    <% if (bookings) { %>
    <% for(let booking of bookings){ %>
        <%= console.log(bookings) %>
        <div class="listing-card card col"> 
            
            <a href="/listings/<%= booking.listing._id %>" class="listing-link">
                
                <img 
                src="<%= booking.listing.images && booking.listing.images.length ? booking.listing.images[0].url : '' %>" 
                class="card-img-top booked-hotel-image" 
                alt="listing_image">

                <div class="card-body">
                    <p class="card-title"><b><%= booking.listing.title %></b></p>
                    <p class="card-location"><%= booking.listing.location %></p>

                    <p class="price">
                        &#8377; <%= booking.totalPrice.toLocaleString("en-IN") %> total
                    </p>

                    <p><strong>Check-in:</strong> <%= booking.checkIn.toDateString() %></p>
                    <p><strong>Check-out:</strong> <%= booking.checkOut.toDateString() %></p>
                </div>

            </a>

            <div class="card-body">
    
                <p class="booking-status">
                    <strong>Status:</strong> 
                    <% if (booking.status === "cancelled") { %>
                        ❌ Cancelled
                    <% } else { %>
                        ✅ Confirmed  
                    <% } %>
                </p>
            
                <% if (booking.status === "confirmed") { %>
                    <form action="/bookings/<%= booking._id %>?_method=DELETE" method="POST">
                        <button class="btn btn-danger w-100">Cancel Booking</button>
                    </form>
                <% } else { %>
                    <button class="btn btn-secondary w-100 cancel-btn" disabled>
                        Booking Cancelled
                    </button>
                <% } %>
            
            </div>

        </div>

    <% } %>
    <% } %>
</div>
</div>
</div>