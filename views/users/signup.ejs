<% layout("/layouts/boilerplate.ejs") %>
<style>
    .add-listing-page{
        background-image:url("/images/signup.avif");
    }
</style>
<div class="add-listing-page">

    <div class="form-container">

        <h2 class="form-title">Create Your Account</h2>
        <p class="form-subtitle">Join WanderLust and start exploring amazing stays.</p>

        <form action="/signup" method="POST" class="needs-validation" novalidate>

            <div class="mb-3">
                <label class="form-label">Username</label>
                <input name="username" id="username" type="text" class="form-control" required>
                <div class="valid-feedback">Looks Good!</div>
            </div>

            <div class="mb-3">
                <label class="form-label">E-mail</label>
                <input name="email" id="email" type="email" class="form-control" required>
            </div>

            <div class="mb-3 position-relative">
                <label for="password" class="form-label">Password</label>
            
                <input name="password" id="password" type="password" class="form-control" required>
                <i class="fa-solid fa-eye password-toggle"></i>
                <div class="valid-feedback">Looks Good!</div>
            </div>

            <div class="d-flex justify-content-center">
                <button class="btn add-btn mt-3">Sign Up</button>
            </div>
            <p class="text-center mt-3 login">
                Already have an account? <a href="/login">Log in</a>
            </p>
            
            <div class="divider">
                <span>OR</span>
            </div>
            
            <a href="/auth/google" class="google-btn">
                <img src="https://www.svgrepo.com/show/475656/google-color.svg" alt="google" />
                <span>Continue with Google</span>
            </a>
        </form>

    </div>

</div>